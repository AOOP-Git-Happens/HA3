<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FlightTracker.ViewModels"
             x:Class="FlightTracker.Views.InfoFlightView"
             x:DataType="vm:InfoFlightViewModel">

    <StackPanel Margin="20" Spacing="10">

        <!--
        <Border Background="Gray"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="3"
                Padding="10" Margin="10">
            <TextBlock>Box 1</TextBlock>
        </Border>
        -->

        <TextBlock Text="{Binding Title}" FontSize="24"/>
        <TextBlock Text="Placeholder for Airport's flight info."/>
        
    </StackPanel>
</UserControl>