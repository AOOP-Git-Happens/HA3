<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FlightTracker.Views.RouteMapView"
             xmlns:vm="using:FlightTracker.ViewModels"
             x:DataType="vm:RouteMapViewModel">

    <!--Search box,
    selected airport text
    clear button
    Mapsui control-->

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="{Binding Header}" FontSize="24"/>
        <TextBlock Text="Placeholder for route visualization and map features."/>
    </StackPanel>
</UserControl>